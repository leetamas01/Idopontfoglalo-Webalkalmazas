@model IdopontfoglaloWebalk.Models.User

@{
    ViewData["Title"] = "Regisztráció";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 p-4">
                <div class="card-body">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold">Fiók létrehozása</h2>
                        <p class="text-muted">Csatlakozz hozzánk és foglald le az első időpontod!</p>
                    </div>

                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <form asp-controller="Users" asp-action="Registration" method="post">

                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label fw-semibold">Felhasználónév</label>
                            <input asp-for="UserName" class="form-control rounded-3" placeholder="mintaferi88" required />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email cím</label>
                            <input asp-for="Email" class="form-control rounded-3" placeholder="pelda@email.hu" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold">Telefonszám</label>
                            <input asp-for="PhoneNumber" class="form-control rounded-3" placeholder="+36301234567" required />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label fw-semibold">Jelszó</label>
                            <input type="password" id="password" name="password" class="form-control rounded-3" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">
                            Regisztráció
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="small text-muted">
                            Már van fiókod?
                            <a asp-controller="Home" asp-action="Login" class="text-primary fw-bold text-decoration-none">Jelentkezz be!</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>