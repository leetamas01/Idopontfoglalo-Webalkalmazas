@{
    ViewData["Title"] = "Home Page";
}
@model IdopontfoglaloWebalk.Models.User

    <div class="section text-center py-5 mb-5">
        <div class="container">
            <h1 class="display-4 fw-bold mb-3">Találd meg a tökéletes időpontot!</h1>
            <p class="lead mb-4">Foglalj egyszerűen online.</p>

            <div class="search-container mx-auto">
                <form action="" method="get" class="d-flex shadow-sm p-2 bg-white rounded-pill">
                    <input type="search" name="search" class="form-control border-0 rounded-pill px-4"
                           placeholder="Milyen szolgáltatást keresel?" required />
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Keresés</button>
                </form>
            </div>
        </div>
    </div>

    <div class="container">
        <h3 class="mb-4 text-center">Népszerű kategóriák</h3>

        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <a href="" class="category-card shadow-sm p-4 d-block text-decoration-none rounded-4">
                    <div class="category-name text-dark fw-semibold">Fodrászat</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="" class="category-card shadow-sm p-4 d-block text-decoration-none rounded-4">
                    <div class="category-name text-dark fw-semibold">Masszázs</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="" class="category-card shadow-sm p-4 d-block text-decoration-none rounded-4">
                    <div class="category-name text-dark fw-semibold">Orvos</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="" class="category-card shadow-sm p-4 d-block text-decoration-none rounded-4">
                    <div class="category-name text-dark fw-semibold">Fogászat</div>
                </a>
            </div>
        </div>
    </div>